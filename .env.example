# GitHub
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_USER=
GITHUB_BASE_BRANCH=main
GITHUB_INCLUDE_PRIVATE=true

# Hugging Face
HF_TOKEN=
HF_NAMESPACE=
HF_REPO_TYPES=model,dataset,space

# Runtime
LOG_LEVEL=INFO
WORK_DIR=work
STATE_DIR=state
STATUS_SITE_DIR=status-site
MAX_FIX_ATTEMPTS=2
REPO_TIMEOUT_SECONDS=300
START_TIMEOUT_SECONDS=45
DRY_RUN=true
CLONE_DEPTH=1

# Optional tools
GITPILOT_ENABLED=false
GITPILOT_BIN=gitpilot
MATRIXLAB_ENABLED=false
MATRIXLAB_FALLBACK_LOCAL=true

# Site
SITE_TITLE=RepoGuardian Health
SITE_DESCRIPTION=Autonomous health and repair dashboard for GitHub and Hugging Face repositories.
SITE_BASE_URL=
